# ===== Renate env template =====
# Copy to `.env` and fill in real values. Never commit `.env`.

# --- Core infra ---
POSTGRES_USER=renate
POSTGRES_PASSWORD=renate
POSTGRES_DB=renate
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://renate:renate@postgres:5432/renate

REDIS_URL=redis://redis:6379

# --- Service ports (host-exposed) ---
API_PORT=3000
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379

# --- Voice assistant ---
# Gate: set to "true" to enable in-call Q&A.
VA_ENABLED=false
OPENAI_API_KEY=
SARVAM_API_KEY=
# Wake word the bot listens for in live captions. Case-insensitive.
WAKE_WORD=renate
# Sarvam TTS settings (English only per current product decision).
TTS_LANGUAGE=en-IN
TTS_SPEAKER=shubh
TTS_MODEL=bulbul:v3

# Latency tuning
# Silence window after last caption before we commit the question (ms).
# Lower = faster replies, but may cut off slow speakers.
VA_SETTLE_MS=500
# Caps the OpenAI reply length. 2–4 sentence replies fit comfortably in 300.
VA_ANSWER_MAX_TOKENS=180
# Streaming pipeline: LLM tokens → sentence-chunked TTS → sequential paplay.
# Starts speaking while the rest of the answer is still being generated.
# On by default — cuts audioStart latency ~2-3s vs the non-streaming path.
# Flip to false to debug using the single-shot path.
VA_STREAMING=true

# --- Bot runtime ---
AUTH_PROFILE=/auth/auth.json
# SESSION_ID=
# MEET_URL=

# --- Logging ---
LOG_LEVEL=info
NODE_ENV=development
